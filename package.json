{
  "name": "active-local-servers",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"pnpm -F @als/server dev\" \"pnpm -F @als/web dev\"",
    "build": "pnpm -F @als/shared build && pnpm -F @als/web build && pnpm -F @als/server build",
    "start": "pnpm -F @als/server start"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.2"
  }
}
